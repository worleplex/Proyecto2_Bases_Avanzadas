              name="ReporteClientes" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="842" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="a1b2c3d4-e5f6-7890-1234-567890abcdef">
    
    <field name="ID" class="java.lang.Object"/>
